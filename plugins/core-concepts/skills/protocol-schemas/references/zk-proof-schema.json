{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://midnight.network/schemas/zk-proof.json",
  "title": "Midnight ZK Proof",
  "description": "Schema for zero-knowledge proofs generated by the Midnight prover",
  "type": "object",
  "properties": {
    "proofSystem": {
      "type": "string",
      "enum": ["groth16", "plonk", "halo2"],
      "description": "Zero-knowledge proving system used"
    },
    "curve": {
      "type": "string",
      "enum": ["bn254", "bls12-381"],
      "description": "Elliptic curve used for the proof"
    },
    "proof": {
      "type": "object",
      "properties": {
        "a": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2,
          "maxItems": 2,
          "description": "G1 elliptic curve point (x, y coordinates)"
        },
        "b": {
          "type": "array",
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 2,
            "maxItems": 2
          },
          "minItems": 2,
          "maxItems": 2,
          "description": "G2 elliptic curve point (2x2 coordinate matrix)"
        },
        "c": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 2,
          "maxItems": 2,
          "description": "G1 elliptic curve point (x, y coordinates)"
        }
      },
      "required": ["a", "b", "c"],
      "description": "Core proof elements"
    },
    "publicInputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Public inputs to the proof"
    },
    "publicOutputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Public outputs from the proof"
    },
    "verificationKey": {
      "type": "string",
      "description": "Base64-encoded verification key"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "circuitName": {
          "type": "string",
          "description": "Name of the circuit that generated the proof"
        },
        "contractAddress": {
          "type": "string",
          "description": "Associated contract address"
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Proof generation timestamp"
        },
        "proverVersion": {
          "type": "string",
          "description": "Version of the prover software"
        }
      },
      "required": ["circuitName", "contractAddress", "generatedAt", "proverVersion"],
      "description": "Proof generation metadata"
    }
  },
  "required": [
    "proofSystem",
    "curve",
    "proof",
    "publicInputs",
    "publicOutputs",
    "verificationKey",
    "metadata"
  ]
}
