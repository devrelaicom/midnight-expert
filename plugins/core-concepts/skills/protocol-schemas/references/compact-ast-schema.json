{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://midnight.network/schemas/compact-ast.json",
  "title": "Compact AST",
  "description": "Schema for the abstract syntax tree produced by the Compact compiler",
  "type": "object",
  "properties": {
    "type": {
      "const": "Program"
    },
    "version": {
      "type": "string",
      "description": "AST schema version"
    },
    "imports": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Imported modules (e.g., CompactStandardLibrary)"
    },
    "ledger": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/LedgerDeclaration"
      },
      "description": "Public ledger state declarations"
    },
    "circuits": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/CircuitDeclaration"
      },
      "description": "Circuit declarations (exported and internal)"
    },
    "witnesses": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/WitnessDeclaration"
      },
      "description": "Witness function declarations"
    },
    "types": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      },
      "description": "Named type definitions"
    }
  },
  "required": ["type", "version", "imports", "ledger", "circuits", "witnesses", "types"],
  "definitions": {
    "LedgerDeclaration": {
      "type": "object",
      "properties": {
        "type": {
          "const": "LedgerDeclaration"
        },
        "name": {
          "type": "string",
          "description": "Ledger field name"
        },
        "fieldType": {
          "type": "string",
          "description": "Type of the ledger field (e.g., Counter, Map<Bytes<32>, Uint<64>>)"
        },
        "exported": {
          "type": "boolean",
          "description": "Whether the field is exported"
        },
        "fields": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/LedgerField"
          },
          "description": "Sub-fields within the ledger declaration"
        }
      },
      "required": ["type", "name", "fieldType", "exported"]
    },
    "LedgerField": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Field name"
        },
        "fieldType": {
          "type": "string",
          "description": "Field type"
        }
      },
      "required": ["name", "fieldType"]
    },
    "CircuitDeclaration": {
      "type": "object",
      "properties": {
        "type": {
          "const": "CircuitDeclaration"
        },
        "name": {
          "type": "string",
          "description": "Circuit name"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Parameter"
          },
          "description": "Circuit parameters"
        },
        "returnType": {
          "type": "string",
          "description": "Return type (e.g., [], Uint<64>, Bytes<32>)"
        },
        "body": {
          "$ref": "#/definitions/BlockStatement",
          "description": "Circuit body"
        },
        "exported": {
          "type": "boolean",
          "description": "Whether the circuit is exported (callable from transactions)"
        },
        "pure": {
          "type": "boolean",
          "description": "Whether the circuit is pure (no ledger access)"
        }
      },
      "required": ["type", "name", "parameters", "returnType", "body", "exported", "pure"]
    },
    "WitnessDeclaration": {
      "type": "object",
      "properties": {
        "type": {
          "const": "WitnessDeclaration"
        },
        "name": {
          "type": "string",
          "description": "Witness function name"
        },
        "parameters": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Parameter"
          },
          "description": "Witness parameters"
        },
        "returnType": {
          "type": "string",
          "description": "Return type"
        }
      },
      "required": ["type", "name", "parameters", "returnType"]
    },
    "Parameter": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Parameter name"
        },
        "paramType": {
          "type": "string",
          "description": "Parameter type"
        }
      },
      "required": ["name", "paramType"]
    },
    "BlockStatement": {
      "type": "object",
      "properties": {
        "type": {
          "const": "BlockStatement"
        },
        "body": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Statement"
          },
          "description": "Statements within the block"
        }
      },
      "required": ["type", "body"]
    },
    "Statement": {
      "oneOf": [
        { "$ref": "#/definitions/VariableDeclaration" },
        { "$ref": "#/definitions/AssertStatement" },
        { "$ref": "#/definitions/ReturnStatement" },
        { "$ref": "#/definitions/ExpressionStatement" },
        { "$ref": "#/definitions/BlockStatement" }
      ]
    },
    "VariableDeclaration": {
      "type": "object",
      "properties": {
        "type": {
          "const": "VariableDeclaration"
        },
        "name": {
          "type": "string",
          "description": "Variable name"
        },
        "varType": {
          "type": "string",
          "description": "Declared type (optional, may be inferred)"
        },
        "init": {
          "$ref": "#/definitions/Expression",
          "description": "Initializer expression"
        }
      },
      "required": ["type", "name", "init"]
    },
    "AssertStatement": {
      "type": "object",
      "properties": {
        "type": {
          "const": "AssertStatement"
        },
        "condition": {
          "$ref": "#/definitions/Expression",
          "description": "Assertion condition"
        },
        "message": {
          "type": "string",
          "description": "Error message on failure"
        }
      },
      "required": ["type", "condition", "message"]
    },
    "ReturnStatement": {
      "type": "object",
      "properties": {
        "type": {
          "const": "ReturnStatement"
        },
        "value": {
          "$ref": "#/definitions/Expression",
          "description": "Return value expression (null for void returns)"
        }
      },
      "required": ["type"]
    },
    "ExpressionStatement": {
      "type": "object",
      "properties": {
        "type": {
          "const": "ExpressionStatement"
        },
        "expression": {
          "$ref": "#/definitions/Expression",
          "description": "The expression"
        }
      },
      "required": ["type", "expression"]
    },
    "Expression": {
      "oneOf": [
        { "$ref": "#/definitions/BinaryExpression" },
        { "$ref": "#/definitions/CallExpression" },
        { "$ref": "#/definitions/MemberExpression" },
        { "$ref": "#/definitions/Identifier" },
        { "$ref": "#/definitions/Literal" }
      ]
    },
    "BinaryExpression": {
      "type": "object",
      "properties": {
        "type": {
          "const": "BinaryExpression"
        },
        "operator": {
          "type": "string",
          "enum": ["+", "-", "*", "/", "%", "==", "!=", "<", ">", "<=", ">=", "&&", "||"],
          "description": "Binary operator"
        },
        "left": {
          "$ref": "#/definitions/Expression",
          "description": "Left operand"
        },
        "right": {
          "$ref": "#/definitions/Expression",
          "description": "Right operand"
        }
      },
      "required": ["type", "operator", "left", "right"]
    },
    "CallExpression": {
      "type": "object",
      "properties": {
        "type": {
          "const": "CallExpression"
        },
        "callee": {
          "$ref": "#/definitions/Expression",
          "description": "Function being called"
        },
        "arguments": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Expression"
          },
          "description": "Call arguments"
        }
      },
      "required": ["type", "callee", "arguments"]
    },
    "MemberExpression": {
      "type": "object",
      "properties": {
        "type": {
          "const": "MemberExpression"
        },
        "object": {
          "$ref": "#/definitions/Expression",
          "description": "Object being accessed"
        },
        "property": {
          "type": "string",
          "description": "Property name"
        }
      },
      "required": ["type", "object", "property"]
    },
    "Identifier": {
      "type": "object",
      "properties": {
        "type": {
          "const": "Identifier"
        },
        "name": {
          "type": "string",
          "description": "Identifier name"
        }
      },
      "required": ["type", "name"]
    },
    "Literal": {
      "type": "object",
      "properties": {
        "type": {
          "const": "Literal"
        },
        "value": {
          "description": "Literal value"
        },
        "literalType": {
          "type": "string",
          "enum": ["number", "string", "boolean"],
          "description": "Type of the literal"
        }
      },
      "required": ["type", "value", "literalType"]
    }
  }
}
