{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://midnight.network/schemas/transaction.json",
  "title": "Midnight Transaction",
  "description": "Schema for Midnight network transactions",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "description": "Transaction format version"
    },
    "hash": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$",
      "description": "Transaction hash (64-character hex with 0x prefix)"
    },
    "contractAddress": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$",
      "description": "Target contract address"
    },
    "circuitName": {
      "type": "string",
      "description": "Name of the circuit being invoked"
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Public inputs to the circuit"
    },
    "proof": {
      "$ref": "#/definitions/Proof",
      "description": "Zero-knowledge proof"
    },
    "publicOutputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Public outputs from circuit execution"
    },
    "stateChanges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/StateChange"
      },
      "description": "Ledger state modifications"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Transaction creation timestamp"
    },
    "sender": {
      "type": "string",
      "pattern": "^0x[a-fA-F0-9]{64}$",
      "description": "Sender address"
    },
    "nonce": {
      "type": "integer",
      "minimum": 0,
      "description": "Replay protection counter"
    },
    "fee": {
      "type": "object",
      "properties": {
        "amount": {
          "type": "string",
          "description": "Fee amount in smallest denomination"
        },
        "token": {
          "type": "string",
          "description": "Fee token identifier"
        }
      },
      "required": ["amount", "token"],
      "description": "Transaction fee"
    }
  },
  "required": [
    "version",
    "hash",
    "contractAddress",
    "circuitName",
    "inputs",
    "proof",
    "publicOutputs",
    "stateChanges",
    "timestamp",
    "sender",
    "nonce",
    "fee"
  ],
  "definitions": {
    "Proof": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["groth16", "plonk"],
          "description": "Proof system used"
        },
        "data": {
          "type": "string",
          "description": "Base64-encoded proof data"
        },
        "publicInputs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Public inputs to the proof"
        }
      },
      "required": ["type", "data", "publicInputs"]
    },
    "StateChange": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["insert", "update", "delete"],
          "description": "Type of state modification"
        },
        "path": {
          "type": "string",
          "description": "Ledger state path being modified"
        },
        "oldValue": {
          "description": "Previous value (null for inserts)"
        },
        "newValue": {
          "description": "New value (null for deletes)"
        }
      },
      "required": ["type", "path"]
    }
  }
}
